{
  "name": "shopsmart-backend",
  "version": "1.0.0",
  "description": "Backend API for ShopSmart",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "DATABASE_URL=${DATABASE_URL:-file:./test.db} npm run prisma:migrate && NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit",
    "test:ci": "DATABASE_URL=${DATABASE_URL:-file:./test.db} npm run prisma:migrate && NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit --ci --coverage",
    "lint": "eslint '**/*.js' --ignore-pattern node_modules --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma migrate deploy || DATABASE_URL=${DATABASE_URL:-file:./dev.db} node scripts/bootstrap-db.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!**/node_modules/**"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-results",
          "outputName": "junit.xml"
        }
      ]
    ]
  }
}
